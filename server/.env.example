# Optional — default 3847 (Render sets PORT automatically)
PORT=3847

# If unset: state is read/written to server/data/state.json
# If set: state is stored in Postgres (Supabase). Run server/schema.sql once, then:
#   DATABASE_URL="postgresql://..." npm run migrate:file-to-pg --prefix server
DATABASE_URL=

# Default on: SSL for Supabase pooler. Set to false only for local non-TLS Postgres.
# DATABASE_SSL=false

